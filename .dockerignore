# Prevent host-specific artifacts from being copied into Docker build contexts

# Client dependencies and build outputs
Client/node_modules
Client/dist
Client/.vite
Client/.fable
Client/.vscode
Client/.vs

# Server/Shared/Entity build outputs
Backend/Server/bin
Backend/Server/obj
Backend/Entity/Migrations/bin
Backend/Entity/Migrations/obj
Shared/bin
Shared/obj
Backend/Entity/bin
Backend/Entity/obj

# Top-level caches (safety)
node_modules
dist
.vite
.fable

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
.git
