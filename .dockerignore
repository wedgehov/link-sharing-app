# Prevent host-specific artifacts from being copied into Docker build contexts

# Client dependencies and build outputs
src/Client/node_modules
src/Client/dist
src/Client/.vite
src/Client/.fable
src/Client/.vscode
src/Client/.vs

# Server/Shared/Entity build outputs
src/Server/bin
src/Server/obj
src/Shared/bin
src/Shared/obj
src/Entity/bin
src/Entity/obj

# Top-level caches (safety)
node_modules
dist
.vite
.fable

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/


